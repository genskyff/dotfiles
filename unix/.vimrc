set termguicolors

set autoread
set showmatch

set number
set relativenumber

set smartcase
set ignorecase
set incsearch

set autoindent
set expandtab
set shiftwidth=4
set smartindent
set smarttab
set softtabstop=4

set noswapfile
set nobackup
set wildmenu
set scrolloff=5
set backspace=indent,eol,start

inoremap jk <Esc>
inoremap kj <Esc>
